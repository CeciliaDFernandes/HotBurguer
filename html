<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HotBurguer · pedido</title>
    <!-- Font Awesome (ícones) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <!-- CSS externo -->
    <link rel="stylesheet" href="style.css" />
</head>
<body>
    <header>
        <div class="container header-flex">
            <div class="logo">
                <i class="fas fa-burger"></i> Hot<span>Burguer</span>
            </div>
            <div class="nav-links">
                <a href="#"><i class="fas fa-home"></i> index</a>
                <a href="#"><i class="fas fa-info-circle"></i> sobre</a>
                <a href="#"><i class="fas fa-image"></i> img</a>
                <a href="#menu"><i class="fas fa-utensils"></i> cardápio</a>
                <!-- link "pedido" corrigido -->
                <a href="#" class="pedido-link"><i class="fas fa-shopping-cart"></i> pedido</a>
            </div>
        </div>
    </header>

    <main class="container">
        <!-- BANNER / HERO -->
        <section class="hero">
            <div class="hero-text">
                <h1>🔥 HotBurguer</h1>
                <p>O sabor que esquenta a alma. <br />Hambúrgueres artesanais, ingredientes de verdade.</p>
                <a href="#menu" class="btn-hero"><i class="fas fa-arrow-right"></i> Ver cardápio</a>
            </div>
            <div class="hero-img">
                <i class="fas fa-hamburger"></i> <i class="fas fa-pepper-hot"></i>
            </div>
        </section>

        <!-- CARDÁPIO (menu) com botão "fazer pedido" cada item -->
        <section class="menu-section" id="menu">
            <h2><i class="fas fa-clipboard-list" style="margin-right: 12px;"></i> Cardápio</h2>
            <div class="menu-grid">
                <!-- item 1 -->
                <div class="card">
                    <div class="card-img"><i class="fas fa-bacon"></i></div>
                    <h3>X-Bacon Supremo</h3>
                    <div class="desc">Pão brioche, hambúrguer 200g, bacon crocante, cheddar e molho especial.</div>
                    <div class="price">R$ 29,90</div>
                    <a href="#" class="btn-pedido"><i class="fas fa-cart-plus"></i> Fazer pedido</a>
                </div>
                <!-- item 2 -->
                <div class="card">
                    <div class="card-img"><i class="fas fa-cheese"></i></div>
                    <h3>Duplo Cheddar</h3>
                    <div class="desc">Dois hambúrgueres, cheddar em dobro, cebola caramelizada e maionese da casa.</div>
                    <div class="price">R$ 34,90</div>
                    <a href="#" class="btn-pedido"><i class="fas fa-cart-plus"></i> Fazer pedido</a>
                </div>
                <!-- item 3 -->
                <div class="card">
                    <div class="card-img"><i class="fas fa-pepper-hot"></i></div>
                    <h3>Chilli Burguer</h3>
                    <div class="desc">Pimenta jalapeño, pepperoni, queijo prato e molho picante exclusivo.</div>
                    <div class="price">R$ 32,50</div>
                    <a href="#" class="btn-pedido"><i class="fas fa-cart-plus"></i> Fazer pedido</a>
                </div>
                <!-- item 4 -->
                <div class="card">
                    <div class="card-img"><i class="fas fa-leaf"></i></div>
                    <h3>Veggie Power</h3>
                    <div class="desc">Hambúrguer de grão-de-bico, abacate, rúcula e maionese de ervas.</div>
                    <div class="price">R$ 28,90</div>
                    <a href="#" class="btn-pedido"><i class="fas fa-cart-plus"></i> Fazer pedido</a>
                </div>
                <!-- item 5 -->
                <div class="card">
                    <div class="card-img"><i class="fas fa-egg"></i></div>
                    <h3>Breakfast Burger</h3>
                    <div class="desc">Ovo frito, queijo mussarela, presunto e molho de mostarda e mel.</div>
                    <div class="price">R$ 26,90</div>
                    <a href="#" class="btn-pedido"><i class="fas fa-cart-plus"></i> Fazer pedido</a>
                </div>
                <!-- item 6 -->
                <div class="card">
                    <div class="card-img"><i class="fas fa-fire"></i></div>
                    <h3>Hot Inferno</h3>
                    <div class="desc">Pimenta habanero, queijo pepper jack, cebola roxa e molho BBQ apimentado.</div>
                    <div class="price">R$ 36,90</div>
                    <a href="#" class="btn-pedido"><i class="fas fa-cart-plus"></i> Fazer pedido</a>
                </div>
            </div>
            <!-- observação: todos os botões levam ao carrinho (simulação) -->
            <p style="text-align: right; margin-top: 1.8rem; font-style: italic; color: #5a3f2e;">
                <i class="fas fa-shopping-cart"></i> Clique em "Fazer pedido" para adicionar ao carrinho.
            </p>
        </section>
    </main>

    <footer>
        <div class="container footer-grid">
            <div>
                <h4>HotBurguer</h4>
                <p style="color: #b8957a; max-width: 200px;">O melhor hambúrguer artesanal da cidade. Sabor que aquece.</p>
            </div>
            <div>
                <h4>Navegação</h4>
                <a href="#"><i class="fas fa-home"></i> index</a>
                <a href="#"><i class="fas fa-info-circle"></i> sobre</a>
                <a href="#"><i class="fas fa-image"></i> img</a>
                <a href="#menu"><i class="fas fa-utensils"></i> cardápio</a>
                <a href="#"><i class="fas fa-shopping-cart"></i> pedido</a>
            </div>
            <div>
                <h4>Contato</h4>
                <a href="#"><i class="fas fa-phone"></i> (11) 99999-9999</a>
                <a href="#"><i class="fas fa-envelope"></i> contato@hotburguer.com</a>
                <a href="#"><i class="fab fa-instagram"></i> @hotburguer</a>
            </div>
        </div>
        <div class="container footer-bottom">
            <p>🍔 HotBurguer · todos os direitos reservados · 2026</p>
            <p style="font-size: 0.8rem; margin-top: 0.3rem;">projeto GitHub · index · sobre · img · cardápio · pedido</p>
        </div>
    </footer>

    <!-- Script para simular pedido -->
    <script>
        (function() {
            const botoes = document.querySelectorAll('.btn-pedido');
            botoes.forEach(btn => {
                btn.addEventListener('click', function(e) {
                    e.preventDefault();
                    const item = this.closest('.card').querySelector('h3')?.innerText || 'item';
                    alert(`🍔 "${item}" adicionado ao carrinho! (simulação)`);
                });
            });
        })();
    </script>
</body>
</html>
